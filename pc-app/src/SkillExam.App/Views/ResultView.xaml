<UserControl x:Class="SkillExam.App.Views.ResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="考试结果页面">
    <Grid>
        <StackPanel Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="考试结束，得分"
                       Style="{StaticResource SectionTitleTextStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding ScoreText}" FontSize="58" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,16,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Result.Passed}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding PassText}" FontSize="22"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center" />
            <TextBlock Text="{Binding Result.MaximumScore, StringFormat=满分 {0} 分}"
                       Style="{StaticResource CaptionTextStyle}"
                       HorizontalAlignment="Center" Margin="0,7,0,28" />

            <Button Content="再来一遍" Command="{Binding BackToHomeCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Width="240" Margin="0,0,0,10" />
            <Button Content="查看本次错题" Command="{Binding ReviewErrorsCommand}"
                    IsEnabled="{Binding HasIncorrectQuestions}"
                    Style="{StaticResource SecondaryButtonStyle}" Width="240" />
        </StackPanel>
    </Grid>
</UserControl>
