<UserControl x:Class="SkillExam.App.Views.PracticeSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:SkillExam.Core.Models;assembly=SkillExam.Core"
             AutomationProperties.Name="专项练习题型选择">
    <Grid Margin="28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="专项练习 - 选择题型"
                   Style="{StaticResource DesktopPageTitleTextStyle}"
                   HorizontalAlignment="Center" />

        <Grid Grid.Row="1" Width="520" Margin="0,22,0,0" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="230" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="选择等级（可多选）" Style="{StaticResource FormLabelTextStyle}" />
                <Border Style="{StaticResource DesktopListBorderStyle}" Height="150">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Levels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}"
                                              Style="{StaticResource DesktopCheckBoxStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="选择类别（可多选）" Style="{StaticResource FormLabelTextStyle}" />
                <Border Style="{StaticResource DesktopListBorderStyle}" Height="150">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}"
                                              Style="{StaticResource DesktopCheckBoxStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Grid>

        <Button Grid.Row="2" Content="刷新题目数量" Command="{Binding RefreshCountsCommand}"
                Style="{StaticResource SecondaryButtonStyle}" Width="220"
                HorizontalAlignment="Center" Margin="0,12,0,16" />

        <StackPanel Grid.Row="3" Width="360" HorizontalAlignment="Center">
            <Button Command="{Binding StartPracticeCommand}" CommandParameter="{x:Static models:QuestionType.SingleChoice}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,9">
                <TextBlock Text="{Binding SingleChoiceCount, StringFormat=单选题练习（可用 {0} 题）}" />
            </Button>
            <Button Command="{Binding StartPracticeCommand}" CommandParameter="{x:Static models:QuestionType.MultipleChoice}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,9">
                <TextBlock Text="{Binding MultipleChoiceCount, StringFormat=多选题练习（可用 {0} 题）}" />
            </Button>
            <Button Command="{Binding StartPracticeCommand}" CommandParameter="{x:Static models:QuestionType.TrueFalse}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,9">
                <TextBlock Text="{Binding TrueFalseCount, StringFormat=判断题练习（可用 {0} 题）}" />
            </Button>
            <Button Command="{Binding StartPracticeCommand}" CommandParameter="{x:Static models:QuestionType.ShortAnswer}"
                    Style="{StaticResource PrimaryButtonStyle}">
                <TextBlock Text="{Binding ShortAnswerCount, StringFormat=简答题练习（可用 {0} 题）}" />
            </Button>
        </StackPanel>

        <Button Grid.Row="5" Content="返回主页" Command="{Binding BackCommand}"
                Style="{StaticResource SecondaryButtonStyle}" Width="220"
                HorizontalAlignment="Center" Margin="0,16,0,0" />
    </Grid>
</UserControl>
