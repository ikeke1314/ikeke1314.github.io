<UserControl x:Class="SkillExam.App.Views.ErrorBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SkillExam.App.Controls"
             AutomationProperties.Name="我的错题本">
    <Grid Margin="26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="我的错题本" Style="{StaticResource DesktopPageTitleTextStyle}" HorizontalAlignment="Center" />
            <TextBlock Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center" Margin="0,5,0,0">
                <Run Text="{Binding TotalQuestions}" /><Run Text=" 道错题，累计 " />
                <Run Text="{Binding TotalAttempts}" /><Run Text=" 次错误作答" />
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="题型" Style="{StaticResource FormLabelTextStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding Filters}" SelectedItem="{Binding SelectedFilter}"
                          DisplayMemberPath="Name" Width="150" Height="36" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="复习当前列表" Command="{Binding ReviewAllCommand}"
                        IsEnabled="{Binding IsEmpty, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                <Button Content="清空错题本" Command="{Binding ClearCommand}"
                        IsEnabled="{Binding IsEmpty, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource DangerButtonStyle}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <controls:EmptyState Title="暂无错题" Message="答错的题目会自动记录在这里。">
                <controls:EmptyState.Style>
                    <Style TargetType="controls:EmptyState">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEmpty}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:EmptyState.Style>
            </controls:EmptyState>

            <ListView ItemsSource="{Binding Items}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      Background="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.Style>
                    <Style TargetType="ListView">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEmpty}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="4,5" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView AllowsColumnReorder="False">
                        <GridViewColumn Header="题型" Width="76" DisplayMemberBinding="{Binding TypeDisplay}" />
                        <GridViewColumn Header="题目" Width="430">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Question.Text}" TextWrapping="Wrap" MaxWidth="410" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="错误答案" Width="90" DisplayMemberBinding="{Binding Item.LastUserAnswer}" />
                        <GridViewColumn Header="正确答案" Width="90" DisplayMemberBinding="{Binding Question.Answer}" />
                        <GridViewColumn Header="答错次数" Width="82" DisplayMemberBinding="{Binding Item.AttemptCount}" />
                        <GridViewColumn Header="操作" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="重新练习"
                                            Command="{Binding DataContext.ReviewOneCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource CompactButtonStyle}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <Button Grid.Row="3" Content="返回主页" Command="{Binding BackCommand}"
                Style="{StaticResource SecondaryButtonStyle}" Width="220"
                HorizontalAlignment="Center" Margin="0,14,0,0" />
    </Grid>
</UserControl>
