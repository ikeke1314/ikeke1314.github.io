<UserControl x:Class="SkillExam.App.Views.QuestionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SkillExam.App.Controls"
             AutomationProperties.Name="答题页面">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <controls:QuestionNavigator Groups="{Binding NavigatorGroups}"
                                    NavigateCommand="{Binding NavigateToCommand}"
                                    Width="300">
            <controls:QuestionNavigator.Style>
                <Style TargetType="controls:QuestionNavigator">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=NavigationToggle}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:QuestionNavigator.Style>
        </controls:QuestionNavigator>

        <Grid Grid.Column="1" Margin="18,12,18,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <controls:ExamHeader Margin="0,0,14,0" />
                <ToggleButton x:Name="NavigationToggle" Grid.Column="1" IsChecked="True"
                              Content="题号导航" Style="{StaticResource CompactToggleStyle}"
                              VerticalAlignment="Center" AutomationProperties.HelpText="显示或隐藏左侧题号导航" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly" Margin="0,6,0,0">
                <controls:QuestionCard VerticalAlignment="Top" />
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="上一题" Command="{Binding PreviousCommand}" IsEnabled="{Binding CanMovePrevious}"
                            Style="{StaticResource SecondaryButtonStyle}" MinWidth="92" Margin="0,0,9,0" />
                    <Button Content="确认答案" Command="{Binding ConfirmAnswerCommand}" MinWidth="108" Margin="0,0,9,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowsConfirmAnswer}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="查看答案" Command="{Binding RevealAnswerCommand}" MinWidth="108" Margin="0,0,9,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowsReferenceAnswer}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="下一题" Command="{Binding NextCommand}" IsEnabled="{Binding CanMoveNext}"
                            Style="{StaticResource SecondaryButtonStyle}" MinWidth="92" />
                </StackPanel>

                <Button Content="{Binding ExitButtonText}" Command="{Binding ExitCommand}"
                        HorizontalAlignment="Right" MinWidth="118">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExam}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="交卷" Command="{Binding SubmitExamCommand}"
                        HorizontalAlignment="Right" MinWidth="118">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExam}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
