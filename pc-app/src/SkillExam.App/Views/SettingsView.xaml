<UserControl x:Class="SkillExam.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="设置页面">
    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="设置" Style="{StaticResource DesktopPageTitleTextStyle}" HorizontalAlignment="Center" />

        <Border Grid.Row="1" Style="{StaticResource DesktopSectionBorderStyle}"
                Width="720" HorizontalAlignment="Center" Margin="0,16,0,10">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <TextBlock Text="语音朗读" Style="{StaticResource SectionTitleTextStyle}" />
                <StackPanel Grid.Column="1">
                    <CheckBox Content="自动读题" IsChecked="{Binding AutoSpeechEnabled}"
                              Style="{StaticResource DesktopCheckBoxStyle}" />
                    <Grid Margin="0,9,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="语音" Style="{StaticResource FormLabelTextStyle}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Voices}" SelectedValue="{Binding VoiceName}"
                                  SelectedValuePath="Name" DisplayMemberPath="Name" Height="36" />
                    </Grid>
                    <Grid Margin="0,9,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="38" /></Grid.ColumnDefinitions>
                        <TextBlock Text="语速" Style="{StaticResource FormLabelTextStyle}" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" Minimum="-10" Maximum="10" TickFrequency="1"
                                IsSnapToTickEnabled="True" Value="{Binding SpeechRate}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding SpeechRate}" Style="{StaticResource BodyTextStyle}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="{Binding VoiceWarning}" Style="{StaticResource CaptionTextStyle}" Margin="80,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DesktopSectionBorderStyle}"
                Width="720" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <TextBlock Text="答题与显示" Style="{StaticResource SectionTitleTextStyle}" />
                <StackPanel Grid.Column="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="62" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="跳题延迟" Style="{StaticResource FormLabelTextStyle}" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="3" TickFrequency="0.1"
                                IsSnapToTickEnabled="True" Value="{Binding AutoNextDelaySeconds}"
                                VerticalAlignment="Center" AutomationProperties.Name="答对后跳题延迟" />
                        <TextBlock Grid.Column="2" Text="{Binding AutoNextDelayDisplay}" Style="{StaticResource BodyTextStyle}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                    <CheckBox Content="减少动画" IsChecked="{Binding ReduceMotion}" Style="{StaticResource DesktopCheckBoxStyle}"
                              Margin="0,12,0,0" />
                    <TextBlock Text="开启后避免非必要的过渡动画。" Style="{StaticResource CaptionTextStyle}" Margin="25,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource DesktopSectionBorderStyle}"
                Width="720" HorizontalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <TextBlock Text="用户数据" Style="{StaticResource SectionTitleTextStyle}" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding DataDirectory}" Style="{StaticResource CaptionTextStyle}"
                               TextWrapping="Wrap" Margin="0,0,0,9" />
                    <WrapPanel>
                        <Button Content="查看数据目录" Command="{Binding OpenDataDirectoryCommand}"
                                Style="{StaticResource CompactButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="备份数据库" Command="{Binding BackupCommand}"
                                Style="{StaticResource CompactButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="恢复默认设置" Command="{Binding ResetCommand}"
                                Style="{StaticResource CompactButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="5" Width="720" HorizontalAlignment="Center" Margin="0,14,0,0">
            <Button Content="返回主页" Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Width="150" HorizontalAlignment="Left" />
            <Button Content="保存设置" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Width="150" HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</UserControl>
