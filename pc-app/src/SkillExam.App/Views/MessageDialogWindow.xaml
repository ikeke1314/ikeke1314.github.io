<Window x:Class="SkillExam.App.Views.MessageDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提示" Width="480" MinHeight="220" Style="{StaticResource DialogWindowStyle}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <TextBlock Text="{Binding DialogTitle}" Style="{StaticResource SectionTitleTextStyle}" />
        <TextBlock Grid.Row="1" Text="{Binding Message}" Style="{StaticResource BodyTextStyle}" Margin="0,16,0,22" VerticalAlignment="Center" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="取消" Click="CancelButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" />
            <Button x:Name="ConfirmButton" Content="确认" Click="ConfirmButton_OnClick" Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
