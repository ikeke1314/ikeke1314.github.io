<UserControl x:Class="SkillExam.App.Controls.ExamHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MinHeight="42">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <WrapPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding ModeDisplay}" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,18,0" />
            <TextBlock Text="进度：" Style="{StaticResource BodyTextStyle}" />
            <TextBlock Text="{Binding ProgressText}" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" />
            <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="5" Padding="8,3" Margin="14,0,0,0">
                <TextBlock Text="{Binding TypeDisplay}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
            </Border>
        </WrapPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="剩余时间：" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExam}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding RemainingTimeText}" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExam}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
