<UserControl x:Class="SkillExam.App.Controls.QuestionNavigator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SkillExam.App.Controls"
             x:Name="Root">
    <Border Background="{StaticResource SurfaceMutedBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
            Padding="14,8,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
            <ItemsControl ItemsSource="{Binding Groups, ElementName=Root}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding TypeDisplay}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="4,8,0,6" />
                            <ItemsControl ItemsSource="{Binding Items}" Width="260" HorizontalAlignment="Left">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding NavigateCommand, RelativeSource={RelativeSource AncestorType={x:Type local:QuestionNavigator}}}"
                                                CommandParameter="{Binding}"
                                                AutomationProperties.Name="{Binding AccessibilityName}"
                                                AutomationProperties.HelpText="点击跳转到该题"
                                                Width="46" Height="38" Margin="3" Padding="0"
                                                Background="{Binding State, Converter={StaticResource NavigationStateToBrushConverter}}"
                                                Foreground="{Binding State, Converter={StaticResource NavigationStateToForegroundConverter}}"
                                                BorderBrush="{Binding State, Converter={StaticResource NavigationStateToBrushConverter}}"
                                                BorderThickness="1" Cursor="Hand" FocusVisualStyle="{x:Null}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="NumberBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <Grid>
                                                            <TextBlock Text="{Binding Number}"
                                                                       Foreground="{TemplateBinding Foreground}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <Ellipse Width="7" Height="7" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                     Margin="0,3,3,0"
                                                                     Fill="{Binding AnswerState, Converter={StaticResource NavigationStateToBrushConverter}}"
                                                                     Stroke="{TemplateBinding Foreground}" StrokeThickness="1" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="NumberBorder" Property="Opacity" Value="0.84" />
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter TargetName="NumberBorder" Property="BorderThickness" Value="3" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                                            <Setter TargetName="NumberBorder" Property="BorderBrush" Value="{StaticResource FocusBrush}" />
                                                            <Setter TargetName="NumberBorder" Property="BorderThickness" Value="3" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Border>
</UserControl>
