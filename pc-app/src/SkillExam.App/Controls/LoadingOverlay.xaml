<UserControl x:Class="SkillExam.App.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root" IsHitTestVisible="True">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive, ElementName=Root}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <Grid Background="#99000000">
        <Border Background="White" CornerRadius="12" Padding="28" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="300">
            <StackPanel>
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,16" Foreground="{StaticResource PrimaryBrush}" />
                <TextBlock Text="{Binding Message, ElementName=Root}" Style="{StaticResource BodyTextStyle}" TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
