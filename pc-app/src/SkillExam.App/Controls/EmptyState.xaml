<UserControl x:Class="SkillExam.App.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource CardBorderStyle}" Padding="36">
        <StackPanel HorizontalAlignment="Center" MaxWidth="520">
            <Border Width="52" Height="52" CornerRadius="16" Background="{StaticResource PrimarySoftBrush}" Margin="0,0,0,16">
                <TextBlock Text="—" Foreground="{StaticResource PrimaryBrush}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding Title, ElementName=Root}" Style="{StaticResource SectionTitleTextStyle}" TextAlignment="Center" />
            <TextBlock Text="{Binding Message, ElementName=Root}" Style="{StaticResource SecondaryTextStyle}" TextAlignment="Center" Margin="0,8,0,0" />
        </StackPanel>
    </Border>
</UserControl>
