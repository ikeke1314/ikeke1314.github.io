<UserControl x:Class="SkillExam.App.Controls.QuestionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SkillExam.App.Controls">
    <Border Style="{StaticResource DesktopQuestionPanelStyle}">
        <StackPanel>
            <TextBlock Text="{Binding QuestionNumberText}"
                       FontFamily="{StaticResource AppFontFamily}"
                       FontSize="20" FontWeight="SemiBold" LineHeight="31"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextWrapping="Wrap" />

            <WrapPanel Margin="0,7,0,10">
                <TextBlock Text="{Binding SourceDisplay, StringFormat=来源：{0}}"
                           Style="{StaticResource CaptionTextStyle}" Margin="0,0,18,3" />
                <TextBlock Text="{Binding LevelDisplay, StringFormat=等级：{0}}"
                           Style="{StaticResource CaptionTextStyle}" Margin="0,0,18,3" />
            </WrapPanel>

            <Button Content="读题" Command="{Binding ReadQuestionCommand}"
                    Style="{StaticResource SpeechButtonStyle}" Width="104"
                    HorizontalAlignment="Left" Margin="0,0,0,12"
                    AutomationProperties.HelpText="朗读当前题目和选项" />

            <ItemsControl ItemsSource="{Binding Options}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:QuestionOptionControl
                            Option="{Binding}"
                            Command="{Binding DataContext.SelectOptionCommand, RelativeSource={RelativeSource AncestorType=controls:QuestionCard}}"
                            IsMultipleChoice="{Binding DataContext.IsMultipleChoice, RelativeSource={RelativeSource AncestorType=controls:QuestionCard}}"
                            IsEnabled="{Binding DataContext.CanAnswerCurrent, RelativeSource={RelativeSource AncestorType=controls:QuestionCard}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Margin="0,4,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShortAnswer}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="请先自行作答，再点击“查看答案”。" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,7" />
                <TextBox Text="{Binding AnswerText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource AnswerTextBoxStyle}"
                         IsEnabled="{Binding CanAnswerCurrent}"
                         AutomationProperties.Name="简答题作答区域" />
                <Border Background="{StaticResource PrimarySoftBrush}" BorderBrush="{StaticResource PrimaryBrush}"
                        BorderThickness="1,0,0,0" Padding="12,9" Margin="0,10,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReferenceVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="参考答案" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ReferenceAnswer}" Style="{StaticResource BodyTextStyle}" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <controls:FeedbackBanner />
        </StackPanel>
    </Border>
</UserControl>
