<UserControl x:Class="SkillExam.App.Controls.FeedbackBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="6" Padding="11,9" Margin="0,10,0,0"
            BorderThickness="1"
            BorderBrush="{Binding FeedbackStatus, Converter={StaticResource AnswerStatusToBrushConverter}}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasFeedback}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                    <DataTrigger Binding="{Binding FeedbackStatus}" Value="Correct"><Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" /></DataTrigger>
                    <DataTrigger Binding="{Binding FeedbackStatus}" Value="Incorrect"><Setter Property="Background" Value="{StaticResource ErrorSoftBrush}" /></DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <TextBlock Text="●" Margin="0,1,9,0"
                       Foreground="{Binding FeedbackStatus, Converter={StaticResource AnswerStatusToBrushConverter}}" />
            <TextBlock Grid.Column="1" Text="{Binding FeedbackMessage}"
                       Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" TextWrapping="Wrap" />
        </Grid>
    </Border>
</UserControl>
